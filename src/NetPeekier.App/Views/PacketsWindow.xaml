<Window x:Class="NetPeekier.App.Views.PacketsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Net-Peekier — Packets"
        Width="900" Height="640" MinWidth="700" MinHeight="460"
        WindowStartupLocation="CenterOwner">

    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Background="#F2F4F6"
                BorderBrush="#D0D5DA" BorderThickness="0,0,0,1" Padding="8,6">
            <DockPanel>
                <Button x:Name="PauseButton" Content="Pause" Width="80" Margin="0,0,8,0"
                        Click="OnTogglePause" />
                <Button Content="Clear" Width="70" Margin="0,0,8,0" Click="OnClear" />
                <TextBlock Text="Filter:" VerticalAlignment="Center" Margin="8,0,4,0" />
                <ComboBox x:Name="FilterCombo" Width="240" VerticalAlignment="Center"
                          SelectionChanged="OnFilterChanged" />
                <TextBlock x:Name="CountLabel" VerticalAlignment="Center"
                           Margin="12,0,0,0" Foreground="#666"
                           DockPanel.Dock="Right" HorizontalAlignment="Right" />
            </DockPanel>
        </Border>

        <!-- "Install Npcap" empty state, shown only when capture is unavailable. -->
        <Border x:Name="NoNpcapPanel" DockPanel.Dock="Top" Background="#FFF8E1"
                BorderBrush="#E6C200" BorderThickness="1" Padding="14" Margin="10"
                Visibility="Collapsed">
            <StackPanel>
                <TextBlock FontWeight="Bold" FontSize="14" Text="Packet capture needs Npcap" />
                <TextBlock TextWrapping="Wrap" Margin="0,6,0,8"
                           Text="The payload / hex view captures packets through Npcap — the same driver Wireshark uses. It isn't bundled (its license requires you install it yourself), but it's a quick, signed installer." />
                <StackPanel Orientation="Horizontal">
                    <Button Content="Download Npcap" Width="140" Click="OnDownloadNpcap" />
                    <Button Content="Re-check" Width="90" Margin="8,0,0,0" Click="OnRecheck" />
                </StackPanel>
                <TextBlock Margin="0,8,0,0" Foreground="#888" TextWrapping="Wrap"
                           Text="During install, leave 'WinPcap API-compatible mode' checked. Restart Net-Peekier (as administrator) afterwards." />
            </StackPanel>
        </Border>

        <!-- Status bar -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem><TextBlock x:Name="StatusLine" Text="" /></StatusBarItem>
        </StatusBar>

        <!-- Split: packet list on top, hex view on the bottom. -->
        <Grid x:Name="CaptureArea">
            <Grid.RowDefinitions>
                <RowDefinition Height="3*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="2*" />
            </Grid.RowDefinitions>

            <DataGrid x:Name="PacketGrid" Grid.Row="0"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False" IsReadOnly="True"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      SelectionMode="Single"
                      SelectionChanged="OnPacketSelected"
                      FontFamily="Consolas" FontSize="12">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Time"   Binding="{Binding Time}"        Width="90"  />
                    <DataGridTextColumn Header="Proc"   Binding="{Binding ProcessName}" Width="120" />
                    <DataGridTextColumn Header="PID"    Binding="{Binding PidText}"     Width="55"  />
                    <DataGridTextColumn Header="Proto"  Binding="{Binding Protocol}"    Width="50"  />
                    <DataGridTextColumn Header="Dir"    Binding="{Binding DirectionArrow}" Width="40" />
                    <DataGridTextColumn Header="Local"  Binding="{Binding Local}"       Width="160" />
                    <DataGridTextColumn Header="Remote" Binding="{Binding Remote}"      Width="160" />
                    <DataGridTextColumn Header="Len"    Binding="{Binding Length}"      Width="60"  />
                </DataGrid.Columns>
            </DataGrid>

            <GridSplitter Grid.Row="1" Height="4" HorizontalAlignment="Stretch"
                          Background="#D0D5DA" />

            <DockPanel Grid.Row="2">
                <TextBlock DockPanel.Dock="Top" Margin="6,4" FontWeight="Bold"
                           Text="Payload (hex / ASCII)" />
                <TextBox x:Name="HexView"
                         FontFamily="Consolas" FontSize="12"
                         IsReadOnly="True"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         TextWrapping="NoWrap"
                         Background="#1E1E1E" Foreground="#D4D4D4"
                         BorderThickness="0" Padding="8" />
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
