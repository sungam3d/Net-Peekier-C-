<Window x:Class="NetPeekier.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:NetPeekier.App.ViewModels"
        mc:Ignorable="d"
        Title="Net-Peekier  -  per-process network monitor"
        Width="880" Height="560" MinWidth="700" MinHeight="420"
        Icon="pack://application:,,,/Assets/icon.png"
        Background="#d6dce4"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel, IsDesignTimeCreatable=False}">

    <Window.Resources>
        <!-- Dashboard typography, ported from the Python build's ttk styles. -->
        <Style x:Key="DashCaption" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#5a93ad" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
        </Style>
        <Style x:Key="DashTinyLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#3d6577" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="9" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="Margin" Value="0,0,5,0" />
        </Style>
        <Style x:Key="DashNow" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="22" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="DashSmall" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <!-- System column cells -->
        <Style x:Key="SysHeader" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#3d6577" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="9" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Margin" Value="8,0,0,0" />
        </Style>
        <Style x:Key="SysRowLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#5a93ad" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,4,0" />
        </Style>
        <Style x:Key="SysVal" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="8,0,0,0" />
        </Style>

        <!-- Clickable column header: flat button that sorts on click. -->
        <Style x:Key="HeaderButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Padding" Value="4,3" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#dbe2ea" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Column-resize grip between headers. Resizes the shared-size column. -->
        <Style x:Key="ColSplitter" TargetType="GridSplitter">
            <Setter Property="Width" Value="5" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
            <Setter Property="Background" Value="#b8c1cc" />
            <Setter Property="ResizeBehavior" Value="PreviousAndNext" />
            <Setter Property="ShowsPreview" Value="True" />
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">

        <!-- Menu bar: File / Statistics / Settings / Help (matches Python) -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="E_xit" Click="OnExit" />
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="_Packets…" Click="OnOpenPackets" />
            </MenuItem>
            <MenuItem Header="Se_ttings">
                <MenuItem Header="_Firewall and Tags…" Click="OnOpenFirewall" />
                <MenuItem Header="_Preferences…" Click="OnOpenSettings" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About" Click="OnAbout" />
            </MenuItem>
        </Menu>

        <!-- ===== Dashboard bar (dark navy, ridge) ===== -->
        <Border DockPanel.Dock="Top" Background="#10212e"
                BorderBrush="#2a4a5e" BorderThickness="2"
                Margin="6,6,6,3" Padding="0,6">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="2" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="2" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- UPLOAD block -->
                <Grid Grid.Column="0" Margin="0,0,0,0" HorizontalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                               Style="{StaticResource DashCaption}" Text="UPLOAD" />
                    <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource DashTinyLabel}" Text="NOW" />
                    <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource DashNow}"
                               Foreground="#ffb454" MinWidth="150" Text="{Binding UpNow}" />
                    <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource DashTinyLabel}" Text="PEAK" />
                    <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource DashSmall}"
                               Foreground="#3d6577" MinWidth="150" Text="{Binding UpPeak}" />
                    <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource DashTinyLabel}" Text="TOTAL" />
                    <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource DashSmall}"
                               Foreground="#8fb6c8" MinWidth="150" Text="{Binding UpTotal}" />
                </Grid>

                <Rectangle Grid.Column="1" Fill="#1d3a4d" Width="2" Margin="0,8" />

                <!-- DOWNLOAD block -->
                <Grid Grid.Column="2" HorizontalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                               Style="{StaticResource DashCaption}" Text="DOWNLOAD" />
                    <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource DashTinyLabel}" Text="NOW" />
                    <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource DashNow}"
                               Foreground="#7fe3ff" MinWidth="150" Text="{Binding DownNow}" />
                    <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource DashTinyLabel}" Text="PEAK" />
                    <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource DashSmall}"
                               Foreground="#3d6577" MinWidth="150" Text="{Binding DownPeak}" />
                    <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource DashTinyLabel}" Text="TOTAL" />
                    <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource DashSmall}"
                               Foreground="#8fb6c8" MinWidth="150" Text="{Binding DownTotal}" />
                </Grid>

                <Rectangle Grid.Column="3" Fill="#1d3a4d" Width="2" Margin="0,8" />

                <!-- SYSTEM block (CPU/GPU/RAM). RAM clock+temp intentionally blank. -->
                <Grid Grid.Column="4" Margin="14,0,16,0" VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="64" />
                        <ColumnDefinition Width="74" />
                        <ColumnDefinition Width="64" />
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="4"
                               Style="{StaticResource DashCaption}" Text="SYSTEM" />
                    <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource SysHeader}" Text="LOAD" />
                    <TextBlock Grid.Row="1" Grid.Column="2" Style="{StaticResource SysHeader}" Text="CLOCK" />
                    <TextBlock Grid.Row="1" Grid.Column="3" Style="{StaticResource SysHeader}" Text="TEMP" />

                    <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource SysRowLabel}" Text="CPU" />
                    <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource SysVal}" Foreground="#ffb454" Text="{Binding CpuLoad}" />
                    <TextBlock Grid.Row="2" Grid.Column="2" Style="{StaticResource SysVal}" Foreground="#8fb6c8" Text="{Binding CpuClock}" />
                    <TextBlock Grid.Row="2" Grid.Column="3" Style="{StaticResource SysVal}" Foreground="#8fb6c8" Text="{Binding CpuTemp}" />

                    <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource SysRowLabel}" Text="GPU" />
                    <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource SysVal}" Foreground="#7fe3ff" Text="{Binding GpuLoad}" />
                    <TextBlock Grid.Row="3" Grid.Column="2" Style="{StaticResource SysVal}" Foreground="#8fb6c8" Text="{Binding GpuClock}" />
                    <TextBlock Grid.Row="3" Grid.Column="3" Style="{StaticResource SysVal}" Foreground="#8fb6c8" Text="{Binding GpuTemp}" />

                    <!-- RAM: load only. Clock + temp removed per request. -->
                    <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource SysRowLabel}" Text="RAM" />
                    <TextBlock Grid.Row="4" Grid.Column="1" Style="{StaticResource SysVal}" Foreground="#a6e3a1" Text="{Binding RamLoad}" />
                </Grid>
            </Grid>
        </Border>

        <!-- ===== Filter / firewall toolbar ===== -->
        <Border DockPanel.Dock="Top" Background="#d6dce4" Padding="8,2,8,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Left: LAN/WAN filters -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <CheckBox Content="Show LAN" IsChecked="{Binding ShowLan, Mode=TwoWay}"
                              VerticalAlignment="Center" />
                    <CheckBox Content="Show WAN" IsChecked="{Binding ShowWan, Mode=TwoWay}"
                              VerticalAlignment="Center" Margin="8,0,0,0" />
                    <TextBlock Foreground="#666" Margin="12,0,0,0" VerticalAlignment="Center"
                               Text="(LAN = local-only traffic; WAN = internet. Edit LAN ranges in Settings.)" />
                </StackPanel>

                <!-- Right: lockdown + firewall master switch + status light -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <CheckBox Content="Lockdown Mode" IsChecked="{Binding LockdownMode, Mode=TwoWay}"
                              VerticalAlignment="Center" Margin="0,0,14,0" />
                    <CheckBox Content="Enable Firewall" IsChecked="{Binding FirewallEnabled, Mode=TwoWay}"
                              VerticalAlignment="Center" />
                    <TextBlock Text="&#x25cf;" FontSize="12" VerticalAlignment="Center"
                               Margin="6,0,2,0" Foreground="{Binding FirewallLightColor}" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- ===== Status bar (bottom) ===== -->
        <Border DockPanel.Dock="Bottom" Background="#c3cbd6">
            <TextBlock Text="{Binding Status}" FontFamily="Segoe UI" FontSize="11"
                       Margin="6,2" />
        </Border>

        <!-- ===== Application list (grouped tree) ===== -->
        <Grid Margin="6,3,6,3">
            <!-- Column header strip aligned to the templates below. -->
            <DockPanel>
                <Border DockPanel.Dock="Top" Background="#c8d0da"
                        BorderBrush="#a9b4c0" BorderThickness="0,0,0,1">
                    <!-- Header strip. Column widths come from the VM, so each
                         row template below binds to the SAME values and they
                         line up exactly. The 18px left pad matches the
                         TreeView item indent (root level has no expander
                         arrow but still inherits a small chrome offset). -->
                    <Grid x:Name="HeaderGrid" Margin="22,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="{Binding Col0Width, Mode=TwoWay}" />
                            <ColumnDefinition Width="5" />
                            <ColumnDefinition Width="{Binding Col1Width, Mode=TwoWay}" />
                            <ColumnDefinition Width="5" />
                            <ColumnDefinition Width="{Binding Col2Width, Mode=TwoWay}" />
                            <ColumnDefinition Width="5" />
                            <ColumnDefinition Width="{Binding Col3Width, Mode=TwoWay}" />
                            <ColumnDefinition Width="5" />
                            <ColumnDefinition Width="{Binding Col4Width, Mode=TwoWay}" />
                            <ColumnDefinition Width="5" />
                            <ColumnDefinition Width="{Binding Col5Width, Mode=TwoWay}" />
                            <ColumnDefinition Width="5" />
                            <ColumnDefinition Width="{Binding Col6Width, Mode=TwoWay}" />
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"  Tag="Display"   Click="OnSortColumn" Content="{Binding SortHeaderProgram}"   Style="{StaticResource HeaderButton}" HorizontalContentAlignment="Center" />
                        <GridSplitter Grid.Column="1"  Style="{StaticResource ColSplitter}" />
                        <Button Grid.Column="2"  Tag="Up"        Click="OnSortColumn" Content="{Binding SortHeaderUpload}"    Style="{StaticResource HeaderButton}" HorizontalContentAlignment="Center" />
                        <GridSplitter Grid.Column="3"  Style="{StaticResource ColSplitter}" />
                        <Button Grid.Column="4"  Tag="Down"      Click="OnSortColumn" Content="{Binding SortHeaderDownload}"  Style="{StaticResource HeaderButton}" HorizontalContentAlignment="Center" />
                        <GridSplitter Grid.Column="5"  Style="{StaticResource ColSplitter}" />
                        <Button Grid.Column="6"  Tag="TotalUp"   Click="OnSortColumn" Content="{Binding SortHeaderTotalUp}"  Style="{StaticResource HeaderButton}" HorizontalContentAlignment="Center" />
                        <GridSplitter Grid.Column="7"  Style="{StaticResource ColSplitter}" />
                        <Button Grid.Column="8"  Tag="TotalDown" Click="OnSortColumn" Content="{Binding SortHeaderTotalDown}" Style="{StaticResource HeaderButton}" HorizontalContentAlignment="Center" />
                        <GridSplitter Grid.Column="9"  Style="{StaticResource ColSplitter}" />
                        <Button Grid.Column="10" Tag="Tag"       Click="OnSortColumn" Content="{Binding SortHeaderTag}"       Style="{StaticResource HeaderButton}" HorizontalContentAlignment="Center" />
                        <GridSplitter Grid.Column="11" Style="{StaticResource ColSplitter}" />
                        <Button Grid.Column="12" Tag="Listening" Click="OnSortColumn" Content="{Binding SortHeaderListening}" Style="{StaticResource HeaderButton}" HorizontalContentAlignment="Center" />
                    </Grid>
                </Border>

                <TreeView x:Name="AppTree"
                          ItemsSource="{Binding Groups}"
                          SelectedItemChanged="OnTreeSelectionChanged"
                          MouseDoubleClick="OnRowDoubleClick"
                          BorderThickness="1" BorderBrush="#a9b4c0"
                          FontFamily="Segoe UI" FontSize="12"
                          VirtualizingStackPanel.IsVirtualizing="True"
                          VirtualizingStackPanel.VirtualizationMode="Recycling">

                    <TreeView.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Show connections"            Click="OnCtxConnections" />
                            <Separator />
                            <MenuItem Header="End Process"                 Click="OnCtxEndProcess" />
                            <MenuItem Header="Open Program Path"           Click="OnCtxOpenPath" />
                            <Separator />
                            <MenuItem Header="Set tag…"                    Click="OnCtxSetTag" />
                            <MenuItem Header="Remove tag"                  Click="OnCtxRemoveTag" />
                            <MenuItem Header="Block (firewall)"            Click="OnCtxBlock" />
                            <MenuItem Header="Unblock"                     Click="OnCtxUnblock" />
                            <MenuItem Header="Allow (Lockdown allow-list)" Click="OnCtxAllow" />
                            <MenuItem Header="Remove from allow-list"      Click="OnCtxRemoveAllow" />
                            <Separator />
                            <MenuItem Header="Firewall and Tags…"          Click="OnOpenFirewall" />
                        </ContextMenu>
                    </TreeView.ContextMenu>

                    <TreeView.Resources>
                        <Style x:Key="CellC" TargetType="TextBlock">
                            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                            <Setter Property="VerticalAlignment" Value="Center" />
                            <Setter Property="HorizontalAlignment" Value="Center" />
                        </Style>

                        <!-- Leaf (PID) template. Column widths bind to the
                             SAME VM properties as the header grid above, so
                             cells line up under their headers exactly. The
                             template's data context is the row (ProcessRow);
                             we use ItemsControl.DataContext to reach the VM. -->
                        <DataTemplate x:Key="LeafTemplate">
                            <Grid DataContext="{Binding}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="{Binding DataContext.Col0Width, RelativeSource={RelativeSource AncestorType=TreeView}}" />
                                    <ColumnDefinition Width="5" />
                                    <ColumnDefinition Width="{Binding DataContext.Col1Width, RelativeSource={RelativeSource AncestorType=TreeView}}" />
                                    <ColumnDefinition Width="5" />
                                    <ColumnDefinition Width="{Binding DataContext.Col2Width, RelativeSource={RelativeSource AncestorType=TreeView}}" />
                                    <ColumnDefinition Width="5" />
                                    <ColumnDefinition Width="{Binding DataContext.Col3Width, RelativeSource={RelativeSource AncestorType=TreeView}}" />
                                    <ColumnDefinition Width="5" />
                                    <ColumnDefinition Width="{Binding DataContext.Col4Width, RelativeSource={RelativeSource AncestorType=TreeView}}" />
                                    <ColumnDefinition Width="5" />
                                    <ColumnDefinition Width="{Binding DataContext.Col5Width, RelativeSource={RelativeSource AncestorType=TreeView}}" />
                                    <ColumnDefinition Width="5" />
                                    <ColumnDefinition Width="{Binding DataContext.Col6Width, RelativeSource={RelativeSource AncestorType=TreeView}}" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"  Text="{Binding Display}"   Style="{StaticResource CellC}" HorizontalAlignment="Left" Foreground="#555" />
                                <TextBlock Grid.Column="2"  Text="{Binding Up}"        Style="{StaticResource CellC}" FontFamily="Consolas" />
                                <TextBlock Grid.Column="4"  Text="{Binding Down}"      Style="{StaticResource CellC}" FontFamily="Consolas" />
                                <TextBlock Grid.Column="6"  Text="{Binding TotalUp}"   Style="{StaticResource CellC}" FontFamily="Consolas" />
                                <TextBlock Grid.Column="8"  Text="{Binding TotalDown}" Style="{StaticResource CellC}" FontFamily="Consolas" />
                                <TextBlock Grid.Column="10" Text="{Binding Tag}"       Style="{StaticResource CellC}" />
                                <TextBlock Grid.Column="12" Text="{Binding Listening}" Style="{StaticResource CellC}" />
                            </Grid>
                        </DataTemplate>
                    </TreeView.Resources>

                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}"
                                                  ItemTemplate="{StaticResource LeafTemplate}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="{Binding DataContext.Col0Width, RelativeSource={RelativeSource AncestorType=TreeView}}" />
                                    <ColumnDefinition Width="5" />
                                    <ColumnDefinition Width="{Binding DataContext.Col1Width, RelativeSource={RelativeSource AncestorType=TreeView}}" />
                                    <ColumnDefinition Width="5" />
                                    <ColumnDefinition Width="{Binding DataContext.Col2Width, RelativeSource={RelativeSource AncestorType=TreeView}}" />
                                    <ColumnDefinition Width="5" />
                                    <ColumnDefinition Width="{Binding DataContext.Col3Width, RelativeSource={RelativeSource AncestorType=TreeView}}" />
                                    <ColumnDefinition Width="5" />
                                    <ColumnDefinition Width="{Binding DataContext.Col4Width, RelativeSource={RelativeSource AncestorType=TreeView}}" />
                                    <ColumnDefinition Width="5" />
                                    <ColumnDefinition Width="{Binding DataContext.Col5Width, RelativeSource={RelativeSource AncestorType=TreeView}}" />
                                    <ColumnDefinition Width="5" />
                                    <ColumnDefinition Width="{Binding DataContext.Col6Width, RelativeSource={RelativeSource AncestorType=TreeView}}" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"  Text="{Binding Display}" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Left" TextTrimming="CharacterEllipsis" Foreground="{Binding RowColor}" />
                                <TextBlock Grid.Column="2"  Text="{Binding Up}"        FontFamily="Consolas" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                <TextBlock Grid.Column="4"  Text="{Binding Down}"      FontFamily="Consolas" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                <TextBlock Grid.Column="6"  Text="{Binding TotalUp}"   FontFamily="Consolas" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                <TextBlock Grid.Column="8"  Text="{Binding TotalDown}" FontFamily="Consolas" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                <TextBlock Grid.Column="10" Text="{Binding Tag}"       VerticalAlignment="Center" HorizontalAlignment="Center" />
                                <TextBlock Grid.Column="12" Text="{Binding Listening}" VerticalAlignment="Center" HorizontalAlignment="Center" TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>

                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                            <Setter Property="Padding" Value="2" />
                        </Style>
                    </TreeView.ItemContainerStyle>
                </TreeView>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
