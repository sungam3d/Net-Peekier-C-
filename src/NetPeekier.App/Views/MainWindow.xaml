<Window x:Class="NetPeekier.App.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:NetPeekier.App.ViewModels"
        mc:Ignorable="d"
        Title="Net-Peekier — per-process network monitor"
        Width="980" Height="620" MinWidth="780" MinHeight="460"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel, IsDesignTimeCreatable=False}">

    <Window.Resources>
        <!-- A discreet visual treatment for blocked / WAN cells. -->
        <Style x:Key="DashLabel" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="#444" />
        </Style>
        <Style x:Key="DashValue" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas" />
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">

        <!-- Menu -->
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="_Settings…" Click="OnOpenSettings" />
                <Separator />
                <MenuItem Header="E_xit" Click="OnExit" />
            </MenuItem>
            <MenuItem Header="_Firewall">
                <MenuItem Header="_Manage firewall…"     Click="OnOpenFirewall" />
                <Separator />
                <MenuItem Header="_Block selected app"   Command="{Binding BlockSelectedCommand}" />
                <MenuItem Header="_Unblock selected app" Command="{Binding UnblockSelectedCommand}" />
                <Separator />
                <MenuItem Header="Firewall _enabled"
                          IsCheckable="True"
                          IsChecked="{Binding FirewallEnabled, Mode=TwoWay}" />
                <Separator />
                <MenuItem Header="Remove _all Net-Peekier rules…"
                          Command="{Binding RemoveAllRulesCommand}" />
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Header="_Statistics…" Click="OnOpenStats" />
                <MenuItem Header="C_onnections…" Click="OnOpenConnections" />
                <MenuItem Header="_Packets…" Click="OnOpenPackets" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About…" Click="OnAbout" />
            </MenuItem>
        </Menu>

        <!-- Status bar -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem><TextBlock Text="{Binding Status}" /></StatusBarItem>
        </StatusBar>

        <!-- Dashboard -->
        <Grid DockPanel.Dock="Top" Margin="8" Height="86">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" BorderBrush="#bbb" BorderThickness="1" Padding="10" Margin="2"
                    Background="#FAFAFA">
                <StackPanel>
                    <TextBlock Style="{StaticResource DashLabel}" Text="UPLOAD ↑" />
                    <TextBlock Style="{StaticResource DashValue}" Text="{Binding UpNow}" />
                    <TextBlock Style="{StaticResource DashValue}" Text="{Binding UpPeak}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="1" BorderBrush="#bbb" BorderThickness="1" Padding="10" Margin="2"
                    Background="#FAFAFA">
                <StackPanel>
                    <TextBlock Style="{StaticResource DashLabel}" Text="DOWNLOAD ↓" />
                    <TextBlock Style="{StaticResource DashValue}" Text="{Binding DownNow}" />
                    <TextBlock Style="{StaticResource DashValue}" Text="{Binding DownPeak}" />
                </StackPanel>
            </Border>

            <Border Grid.Column="2" BorderBrush="#bbb" BorderThickness="1" Padding="10" Margin="2"
                    Background="#FAFAFA">
                <StackPanel>
                    <TextBlock Style="{StaticResource DashLabel}" Text="SESSION" />
                    <TextBlock Style="{StaticResource DashValue}" Text="{Binding SessionTotal}" />
                </StackPanel>
            </Border>
        </Grid>

        <!-- App list (grouped tree: process name -> PIDs) -->
        <DockPanel>
            <!-- Column header strip, aligned to the templates below. The
                 left pad (28px) lines the headers up past the TreeView's
                 expander toggle so columns sit under their data. -->
            <Border DockPanel.Dock="Top" Background="#EEF1F4"
                    BorderBrush="#D0D5DA" BorderThickness="0,0,0,1">
                <Grid Margin="28,4,16,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="90"  />
                        <ColumnDefinition Width="90"  />
                        <ColumnDefinition Width="90"  />
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="70"  />
                        <ColumnDefinition Width="55"  />
                        <ColumnDefinition Width="*"   />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Process"         FontWeight="Bold" />
                    <TextBlock Grid.Column="1" Text="↑ Upload"        FontWeight="Bold" />
                    <TextBlock Grid.Column="2" Text="↓ Download"      FontWeight="Bold" />
                    <TextBlock Grid.Column="3" Text="Total"           FontWeight="Bold" />
                    <TextBlock Grid.Column="4" Text="Listening Ports" FontWeight="Bold" />
                    <TextBlock Grid.Column="5" Text="Tag"             FontWeight="Bold" />
                    <TextBlock Grid.Column="6" Text="Blocked"         FontWeight="Bold" />
                    <TextBlock Grid.Column="7" Text="WAN"             FontWeight="Bold" />
                </Grid>
            </Border>

            <TreeView x:Name="AppTree"
                      ItemsSource="{Binding Groups}"
                      SelectedItemChanged="OnTreeSelectionChanged"
                      MouseDoubleClick="OnRowDoubleClick"
                      BorderThickness="0"
                      VirtualizingStackPanel.IsVirtualizing="True"
                      VirtualizingStackPanel.VirtualizationMode="Recycling">

                <TreeView.Resources>
                    <!-- Shared row layout used by both group and leaf rows so
                         columns line up regardless of node depth. -->
                    <Style x:Key="RowCell" TargetType="TextBlock">
                        <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                        <Setter Property="VerticalAlignment" Value="Center" />
                    </Style>

                    <!-- Leaf (PID) template. -->
                    <DataTemplate x:Key="LeafTemplate">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="90"  />
                                <ColumnDefinition Width="90"  />
                                <ColumnDefinition Width="90"  />
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="70"  />
                                <ColumnDefinition Width="55"  />
                                <ColumnDefinition Width="*"   />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Display}"   Style="{StaticResource RowCell}" Foreground="#555" />
                            <TextBlock Grid.Column="1" Text="{Binding Up}"        Style="{StaticResource RowCell}" FontFamily="Consolas" />
                            <TextBlock Grid.Column="2" Text="{Binding Down}"      Style="{StaticResource RowCell}" FontFamily="Consolas" />
                            <TextBlock Grid.Column="3" Text="{Binding Total}"     Style="{StaticResource RowCell}" FontFamily="Consolas" />
                            <TextBlock Grid.Column="4" Text="{Binding Listening}" Style="{StaticResource RowCell}" />
                            <TextBlock Grid.Column="5" Text="{Binding Tag}"       Style="{StaticResource RowCell}" />
                            <CheckBox  Grid.Column="6" IsChecked="{Binding Blocked, Mode=OneWay}" IsHitTestVisible="False" VerticalAlignment="Center" />
                            <CheckBox  Grid.Column="7" IsChecked="{Binding UsesWan, Mode=OneWay}" IsHitTestVisible="False" VerticalAlignment="Center" />
                        </Grid>
                    </DataTemplate>
                </TreeView.Resources>

                <!-- Group (process-name) template: hierarchical, children are
                     ProcessRow leaves rendered with the leaf template. -->
                <TreeView.ItemTemplate>
                    <HierarchicalDataTemplate ItemsSource="{Binding Children}"
                                              ItemTemplate="{StaticResource LeafTemplate}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="90"  />
                                <ColumnDefinition Width="90"  />
                                <ColumnDefinition Width="90"  />
                                <ColumnDefinition Width="150" />
                                <ColumnDefinition Width="70"  />
                                <ColumnDefinition Width="55"  />
                                <ColumnDefinition Width="*"   />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="{Binding Display}"   FontWeight="SemiBold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="1" Text="{Binding Up}"        FontFamily="Consolas" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="2" Text="{Binding Down}"      FontFamily="Consolas" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="3" Text="{Binding Total}"     FontFamily="Consolas" FontWeight="SemiBold" VerticalAlignment="Center" />
                            <TextBlock Grid.Column="4" Text="{Binding Listening}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                            <TextBlock Grid.Column="5" Text="{Binding Tag}"       VerticalAlignment="Center" />
                            <CheckBox  Grid.Column="6" IsChecked="{Binding Blocked, Mode=OneWay}" IsHitTestVisible="False" VerticalAlignment="Center" />
                            <CheckBox  Grid.Column="7" IsChecked="{Binding UsesWan, Mode=OneWay}" IsHitTestVisible="False" VerticalAlignment="Center" />
                        </Grid>
                    </HierarchicalDataTemplate>
                </TreeView.ItemTemplate>

                <TreeView.ItemContainerStyle>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
                        <Setter Property="Padding" Value="2" />
                    </Style>
                </TreeView.ItemContainerStyle>
            </TreeView>
        </DockPanel>
    </DockPanel>
</Window>
