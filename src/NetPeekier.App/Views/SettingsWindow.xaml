<Window x:Class="NetPeekier.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Net-Peekier — Preferences"
        Width="540" Height="500" MinWidth="460" MinHeight="420"
        WindowStartupLocation="CenterOwner">

    <DockPanel>
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="14,10,14,14">
            <Button Content="OK"     Width="80" Margin="0,0,8,0" IsDefault="True"
                    Click="OnOk" />
            <Button Content="Cancel" Width="80" IsCancel="True"
                    Click="OnCancel" />
        </StackPanel>

        <Grid Margin="14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="180" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="34" />
                <RowDefinition Height="34" />
                <RowDefinition Height="34" />
                <RowDefinition Height="34" />
                <RowDefinition Height="34" />
                <RowDefinition Height="*"  />
            </Grid.RowDefinitions>

            <!-- speed unit -->
            <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center"
                       Text="Speed unit:" />
            <ComboBox  Grid.Row="0" Grid.Column="1" x:Name="UnitBox"
                       VerticalAlignment="Center" />

            <!-- idle hide -->
            <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center"
                       Text="Hide idle processes after:" />
            <DockPanel Grid.Row="1" Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text=" minutes (blank = never hide)"
                           DockPanel.Dock="Right" Foreground="#666"
                           VerticalAlignment="Center" Margin="6,0,0,0" />
                <TextBox x:Name="IdleBox" Width="80" HorizontalAlignment="Left" />
            </DockPanel>

            <!-- lockdown -->
            <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center"
                       Text="Lockdown mode:" />
            <CheckBox  Grid.Row="2" Grid.Column="1" x:Name="LockdownCheck"
                       VerticalAlignment="Center"
                       Content="Block unknown apps and prompt before letting them out" />

            <!-- allow minutes -->
            <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center"
                       Text="Temp-allow duration:" />
            <DockPanel Grid.Row="3" Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text=" minutes" DockPanel.Dock="Right" Foreground="#666"
                           VerticalAlignment="Center" Margin="6,0,0,0" />
                <TextBox x:Name="AllowMinBox" Width="80" HorizontalAlignment="Left" />
            </DockPanel>

            <!-- packet purge -->
            <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center"
                       Text="Forget pids after:" />
            <DockPanel Grid.Row="4" Grid.Column="1" VerticalAlignment="Center">
                <TextBlock Text=" minutes (blank = never)" DockPanel.Dock="Right"
                           Foreground="#666" VerticalAlignment="Center" Margin="6,0,0,0" />
                <TextBox x:Name="PurgeBox" Width="80" HorizontalAlignment="Left" />
            </DockPanel>

            <!-- LAN ranges -->
            <DockPanel Grid.Row="5" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,12,0,0">
                <TextBlock DockPanel.Dock="Top" Text="LAN ranges (CIDR, one per line):" />
                <TextBlock DockPanel.Dock="Bottom" Foreground="#666" TextWrapping="Wrap"
                           Text="An IP outside every range listed is treated as WAN (internet) traffic. Default ranges cover private + loopback + link-local for IPv4 and IPv6." />
                <TextBox x:Name="LanBox"
                         AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                         FontFamily="Consolas" />
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
