<Window x:Class="NetPeekier.App.Views.FirewallWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Net-Peekier — Firewall Manager"
        Width="900" Height="600" MinWidth="700" MinHeight="450">

    <DockPanel>
        <!-- Master switch row -->
        <Border DockPanel.Dock="Top" Background="#FAFAFA" BorderBrush="#DDD"
                BorderThickness="0,0,0,1" Padding="10,8">
            <DockPanel>
                <CheckBox x:Name="EnabledCheck"
                          Content="Firewall enabled"
                          FontWeight="Bold"
                          VerticalAlignment="Center"
                          Click="OnToggleEnabled" />
                <TextBlock x:Name="EngineStatus"
                           Margin="20,0,0,0"
                           VerticalAlignment="Center"
                           Foreground="#666"
                           DockPanel.Dock="Right"
                           HorizontalAlignment="Right" />
            </DockPanel>
        </Border>

        <!-- Action toolbar -->
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="10"
                    HorizontalAlignment="Right">
            <Button Content="Add IP rule…"      Width="110" Margin="0,0,8,0"
                    Click="OnAddIpRule" />
            <Button Content="Remove selected"   Width="110" Margin="0,0,8,0"
                    Click="OnRemoveSelectedRule" />
            <Button Content="Remove all rules…" Width="120" Margin="0,0,8,0"
                    Click="OnRemoveAll" />
            <Button Content="Close"             Width="80"
                    Click="OnClose" />
        </StackPanel>

        <TabControl Margin="10">
            <TabItem Header="Blocked apps">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Margin="0,4,0,8" Foreground="#666"
                               TextWrapping="Wrap"
                               Text="Apps listed here cannot make or accept network connections. Click an app and choose Unblock to lift the block, or use the main window to block new apps." />
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="Unblock selected" Click="OnUnblockSelected" Width="120" />
                    </StackPanel>
                    <ListBox x:Name="BlockedList"
                             FontFamily="Consolas"
                             SelectionMode="Single" />
                </DockPanel>
            </TabItem>

            <TabItem Header="Allowed apps">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Margin="0,4,0,8" Foreground="#666"
                               TextWrapping="Wrap"
                               Text="In Lockdown mode these apps are permanently allowed to use the internet without prompting. Remove an app to make Lockdown ask again next time it connects." />
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="Remove from allow-list" Click="OnRemoveAllowed" Width="160" />
                    </StackPanel>
                    <ListBox x:Name="AllowedList"
                             FontFamily="Consolas"
                             SelectionMode="Single" />
                </DockPanel>
            </TabItem>

            <TabItem Header="IP rules">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Margin="0,4,0,8" Foreground="#666"
                               TextWrapping="Wrap"
                               Text="Per-app rules: allow rules build a strict whitelist for the app (every other IP/port is blocked). Block rules just deny specific endpoints." />
                    <DataGrid x:Name="RulesGrid"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Exe"       Binding="{Binding Exe}"       Width="240" />
                            <DataGridTextColumn Header="Action"    Binding="{Binding Action}"    Width="70"  />
                            <DataGridTextColumn Header="Dir"       Binding="{Binding Direction}" Width="50"  />
                            <DataGridTextColumn Header="Remote IP" Binding="{Binding RemoteIp}"  Width="170" />
                            <DataGridTextColumn Header="Ports"     Binding="{Binding Ports}"     Width="120" />
                            <DataGridTextColumn Header="Proto"     Binding="{Binding Protocol}"  Width="60"  />
                            <DataGridTextColumn Header="Note"      Binding="{Binding Note}"      Width="*"   />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>

            <TabItem Header="Tag rules">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Margin="0,4,0,8" Foreground="#666"
                               TextWrapping="Wrap"
                               Text="Tags group apps together. A blocked tag blocks every app that carries it; an allowed tag whitelists them in Lockdown. Assign tags from the main window's right-click menu." />
                    <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="Block tag"   Click="OnBlockTag"   Width="90" Margin="0,0,8,0" />
                        <Button Content="Unblock tag" Click="OnUnblockTag" Width="90" Margin="0,0,8,0" />
                        <Button Content="Allow tag"   Click="OnAllowTag"   Width="90" Margin="0,0,8,0" />
                        <Button Content="Unallow tag" Click="OnUnallowTag" Width="90" />
                    </StackPanel>
                    <DataGrid x:Name="TagGrid"
                              AutoGenerateColumns="False"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              SelectionMode="Single">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Tag"      Binding="{Binding Tag}"     Width="200" />
                            <DataGridTextColumn Header="Apps"     Binding="{Binding Count}"   Width="70"  />
                            <DataGridTextColumn Header="Blocked"  Binding="{Binding Blocked}" Width="80"  />
                            <DataGridTextColumn Header="Allowed"  Binding="{Binding Allowed}" Width="80"  />
                            <DataGridTextColumn Header="Members"  Binding="{Binding Members}" Width="*"   />
                        </DataGrid.Columns>
                    </DataGrid>
                </DockPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
