<Window x:Class="NetPeekier.App.Views.IpRuleDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add IP rule"
        Width="500" Height="380"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">

    <Grid Margin="14">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="36" />
            <RowDefinition Height="36" />
            <RowDefinition Height="36" />
            <RowDefinition Height="36" />
            <RowDefinition Height="36" />
            <RowDefinition Height="36" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Text="Executable:" />
        <TextBox   Grid.Row="0" Grid.Column="1" x:Name="ExeBox" VerticalAlignment="Center" />
        <Button    Grid.Row="0" Grid.Column="2" Content="Browse…" Margin="6,0,0,0"
                   Padding="6,0" Click="OnBrowse" />

        <TextBlock Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Text="Action:" />
        <ComboBox  Grid.Row="1" Grid.Column="1" x:Name="ActionBox" VerticalAlignment="Center"
                   SelectedIndex="0">
            <ComboBoxItem Content="block" />
            <ComboBoxItem Content="allow" />
        </ComboBox>

        <TextBlock Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Text="Direction:" />
        <ComboBox  Grid.Row="2" Grid.Column="1" x:Name="DirBox" VerticalAlignment="Center"
                   SelectedIndex="0">
            <ComboBoxItem Content="out" />
            <ComboBoxItem Content="in" />
            <ComboBoxItem Content="both" />
        </ComboBox>

        <TextBlock Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Text="Remote IP / CIDR:" />
        <TextBox   Grid.Row="3" Grid.Column="1" x:Name="IpBox" VerticalAlignment="Center"
                   Text="any" />

        <TextBlock Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Text="Ports:" />
        <TextBox   Grid.Row="4" Grid.Column="1" x:Name="PortsBox" VerticalAlignment="Center" />

        <TextBlock Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" Text="Protocol:" />
        <ComboBox  Grid.Row="5" Grid.Column="1" x:Name="ProtoBox" VerticalAlignment="Center"
                   SelectedIndex="0">
            <ComboBoxItem Content="any" />
            <ComboBoxItem Content="tcp" />
            <ComboBoxItem Content="udp" />
        </ComboBox>

        <TextBlock Grid.Row="6" Grid.Column="0" Grid.ColumnSpan="3"
                   TextWrapping="Wrap" Margin="0,10,0,0" Foreground="#666"
                   Text="Allow rules build a strict whitelist for the app: every endpoint NOT listed in allows for this app becomes blocked. Block rules deny only the specific endpoints listed." />

        <StackPanel Grid.Row="7" Grid.Column="0" Grid.ColumnSpan="3"
                    Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="OK"     Width="80" Margin="0,0,8,0" IsDefault="True"
                    Click="OnOk" />
            <Button Content="Cancel" Width="80" IsCancel="True"
                    Click="OnCancel" />
        </StackPanel>
    </Grid>
</Window>
